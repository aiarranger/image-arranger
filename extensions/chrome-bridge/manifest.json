{
  "manifest_version": 3,
  "name": "image-arranger Chrome Bridge",
  "version": "0.1.0",
  "description": "Lets image-arranger queue processors reuse marker tabs in this signed-in Chrome profile.",
  "permissions": [
    "debugger",
    "identity",
    "identity.email",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:4218/*",
    "https://chatgpt.com/*",
    "https://www.vidu.com/*",
    "https://vidu.com/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  }
}
