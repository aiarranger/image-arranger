      "durationSec": 7.546485260770975
    },
    {
      "id": "h03",
      "plannedStartSec": 13.0,
      "text": "その整理を、生成の流れごと残せるようにします。",
      "startSec": 15.082131519274377,
      "endSec": 19.935102040816325,
      "file": "05-edit/audio/hero-2min-h03.wav",
      "sampleRate": 44100,
