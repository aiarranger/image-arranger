      "durationSec": 6.791836734693877
    },
    {
      "id": "h06",
      "plannedStartSec": 32.0,
      "text": "生成結果だけでなく、作った理由も一緒に残せるのが特徴です。",
      "startSec": 36.62560090702948,
      "endSec": 42.616349206349206,
      "file": "05-edit/audio/hero-2min-h06.wav",
      "sampleRate": 44100,
      "durationSec": 5.990748299319728
    },
    {
      "id": "h07",
      "plannedStartSec": 38.0,
      "text": "キャラクター設定を残しておけば、顔、服、表情をあとから見返せます。",
      "lockedFile": "05-edit/audio/locked-cues/hero-2min-h07.wav",
