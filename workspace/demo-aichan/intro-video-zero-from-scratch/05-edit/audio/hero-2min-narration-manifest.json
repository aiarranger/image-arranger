      "sampleRate": 44100,
      "durationSec": 9.148662131519274
    },
    {
      "id": "h05",
      "plannedStartSec": 25.5,
      "text": "ギャラリー、キュー、詳細画面。採用状態まで確認できます。",
      "lockedFile": "05-edit/audio/locked-cues/hero-2min-h05.wav",
