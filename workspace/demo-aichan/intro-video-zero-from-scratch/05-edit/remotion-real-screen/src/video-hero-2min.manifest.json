  "narration": [
    { "id": "h01", "startSec": 0.0, "text": "画像生成を試しているうちに、ファイルやプロンプトが散らかっていませんか。" },
    { "id": "h02", "startSec": 6.5, "text": "気に入った一枚があっても、元の参考リンクや設定を探すだけで時間がかかります。" },
    { "id": "h03", "startSec": 13.0, "text": "その整理を、生成の流れごと残せるようにします。" },
    { "id": "h04", "startSec": 18.0, "text": "イメージアレンジャーなら、画像、動画、テキスト、参照元をひとつの画面で管理できます。" },
    { "id": "h05", "startSec": 25.5, "text": "ギャラリー、キュー、詳細画面。採用状態まで確認できます。" },
    { "id": "h06", "startSec": 32.0, "text": "生成結果だけでなく、作った理由も一緒に残せるのが特徴です。" },
    { "id": "h07", "startSec": 38.0, "text": "キャラクター設定を残しておけば、顔、服、表情をあとから見返せます。" },
    { "id": "h08", "startSec": 47.5, "text": "生成結果は並べて比較。良かったものには採用済みマーク。" },
    { "id": "h09", "startSec": 56.0, "text": "画像だけでなく、動画の最初と最後の画像も、同じ流れで扱えます。" },
    { "id": "h10", "startSec": 65.0, "text": "あとから再現したり、改善したりしやすくなります。" },
    { "id": "h11", "startSec": 72.0, "text": "参考にしたい投稿やページを見つけたら、ユーアールエルをコピーします。" },
    { "id": "h12", "startSec": 78.5, "text": "参考リンクを貼るだけで、次の生成作業へ進みます。" },
    { "id": "h13", "startSec": 86.5, "text": "できたテキストも、生成画像も、同じ場所に戻ります。" },
    { "id": "h14", "startSec": 95.0, "text": "気になるところは、元の依頼を見ながら、もう一度生成。改善の履歴を残せます。" },
    { "id": "h15", "startSec": 103.0, "text": "一度きりの生成で終わらず、育てていけます。" },
    { "id": "h16", "startSec": 108.0, "text": "無料でダウンロードして、コーデックスから起動。" },
    { "id": "h17", "startSec": 112.5, "text": "自分の画像を入れて、すぐ試せます。" },
    { "id": "h18", "startSec": 116.5, "text": "名前は、画面どおりです。" }
  ],
